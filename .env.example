# Heimdall 环境变量配置模板
# 使用方法: 复制此文件为 .env 并填写实际值
# cp .env.example .env

# ==========================================
# AI 服务配置
# ==========================================
# DeepSeek API Key (必填)
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-actual-api-key-here

# ==========================================
# 交易所配置（可选，默认使用 settings.py 中的配置）
# ==========================================
# EXCHANGE_ID=binance
# TIMEFRAME=1h

# ==========================================
# 高级配置（可选）
# ==========================================
# LOG_LEVEL=INFO
# MAX_RETRIES=3
