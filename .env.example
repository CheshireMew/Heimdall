# ===========================================
# Heimdall Environment Configuration
# Copy this file to .env and fill in your values
# cp .env.example .env
# ===========================================

# --- Required: API Keys ---
# DeepSeek AI (https://platform.deepseek.com/)
DEEPSEEK_API_KEY=

# FRED Economic Data (https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# Alpha Vantage (https://www.alphavantage.co/support/#api-key) - Optional
ALPHA_VANTAGE_API_KEY=

# --- Database ---
# DATABASE_URL has highest priority.
# If DATABASE_URL is empty, the app will try the local PostgreSQL dev database first,
# and will stop instead of silently writing to SQLite when that database is unavailable.
# Set ALLOW_SQLITE_FALLBACK=true only for local disposable development.
# PostgreSQL dev URL can be overridden as a whole:
# POSTGRES_DEV_URL=postgresql://user:password@localhost:5432/heimdall
# Or by parts:
# POSTGRES_DEV_HOST=localhost
# POSTGRES_DEV_PORT=5432
# POSTGRES_DEV_DB=heimdall
# POSTGRES_DEV_USER=postgres
# POSTGRES_DEV_PASSWORD=
DATABASE_URL=
ALLOW_SQLITE_FALLBACK=false

# --- Redis (optional, will degrade gracefully if unavailable) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:4173,http://127.0.0.1:4173,http://localhost:8000,http://127.0.0.1:8000

# --- Logging ---
LOG_LEVEL=INFO
# Set to enable file logging (e.g., logs/heimdall.log)
LOG_FILE=

# --- Rate Limiting ---
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_HEAVY=10/minute

# --- Advanced (usually no need to change) ---
# EXCHANGE_MAX_RETRIES=3
# EXCHANGE_RETRY_DELAY=2
# EXCHANGE_TASK_TIMEOUT=90
# EXCHANGE_FETCH_LIMIT=1000
# REDIS_KLINE_TTL=300
# WS_UPDATE_INTERVAL=5
# API_MAX_LIMIT=5000
# HISTORY_DEFAULT_LIMIT=500
# INDICATORS_DEFAULT_DAYS=30
# DCA_CACHE_TTL=600
# LLM_TEMPERATURE=0.1
# LLM_REQUEST_TIMEOUT=30.0
# MARKET_CRON_INTERVAL_HOURS=4
# KLINE_RETENTION_DAYS=365
# BACKTEST_RETENTION_DAYS=90
